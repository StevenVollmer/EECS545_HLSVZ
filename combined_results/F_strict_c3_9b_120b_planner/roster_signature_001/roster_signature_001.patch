@@ -1,3 +1,15 @@
 def lead_display_name(lead: str) -> str:
-    cleaned = '-'.join(part.strip().lower() for part in lead.split('-'))
-    return cleaned[:1].upper() + cleaned[1:]
+    parts = lead.split('-')
+    cleaned_parts = []
+    for part in parts:
+        part = part.strip()
+        if "'" in part:
+            # Handle apostrophes: capitalize each segment while preserving apostrophes
+            segments = part.split("'")
+            capitalized = "'".join(seg.capitalize() for seg in segments)
+            cleaned_parts.append(capitalized)
+        else:
+            # No apostrophe: capitalize first letter of each segment
+            capitalized = part.capitalize()
+            cleaned_parts.append(capitalized)
+    return '-'.join(cleaned_parts)
