 def title_case_words(value: str) -> str:
     return " ".join(word.capitalize() for word in value.split(" "))
+
+
+def capitalize_preserve_apostrophe(value: str) -> str:
+    # Capitalize each word while preserving apostrophes within words
+    words = value.split(" ")
+    result = []
+    for word in words:
+        if "'" in word:
+            # Handle words with apostrophes like O'Connor
+            parts = word.split("'")
+            capitalized = parts[0].capitalize() + "'" + parts[1].capitalize()
+        else:
+            capitalized = word.capitalize()
+        result.append(capitalized)
+    return " ".join(result)
