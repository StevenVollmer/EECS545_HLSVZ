 def normalize_label(value: str) -> str:
     """Prepare a user-facing label for display."""
+    # Strip leading/trailing whitespace, but preserve internal spacing
+    value = value.strip()
+    # Split only on whitespace sequences, then rejoin with single spaces
+    # This preserves multiple spaces between words as-is
     parts = value.split()
     return " ".join(parts)
