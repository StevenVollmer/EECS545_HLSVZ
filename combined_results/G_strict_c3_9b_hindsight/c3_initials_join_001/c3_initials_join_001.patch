diff --git a/initials.py b/initials.py
index 0ed82af..eade2d0 100644
--- a/initials.py
+++ b/initials.py
@@ -1,2 +1,8 @@
-def initials(name: str) -> str:
-    return "".join(piece[0] for piece in name.split()).lower()
+def initials(name: str, case: str = "upper") -> str:
+    result = "".join(piece[0] for piece in name.split())
+    if case == "upper":
+        return result.upper()
+    elif case == "lower":
+        return result.lower()
+    else:
+        return result
