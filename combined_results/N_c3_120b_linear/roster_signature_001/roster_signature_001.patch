+    """Return a properly formatted lead display name.
+
+    Handles hyphens and apostrophes by capitalizing the first character of each
+    sub‑word. For example, "d'arcy-lee" becomes "D'Arcy-Lee".
+    """
+    import re
+    # Normalize to lower case
+    cleaned = lead.lower()
+    # Capitalize after start, hyphen, or apostrophe
+    def _cap(match: re.Match) -> str:
+        return match.group(1) + match.group(2).upper()
+    return re.sub(r"(^|[-'])([a-z])", _cap, cleaned)
